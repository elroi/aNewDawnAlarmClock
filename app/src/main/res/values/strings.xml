<resources>
    <string name="app_name">LemurLoop</string>

    <!-- Onboarding - Page 1 -->
    <string name="onboarding_back">Back</string>
    <string name="onboarding_1_title">Meet Your New Wake-Up Companion</string>
    <string name="onboarding_1_body">LemurLoop is the alarm that doesn\'t just wake you up — it makes it fun! \nIt briefs you on the weather, your calendar, and a morning mission, all configurable and delivered in the voice of a character you choose.</string>
    <string name="onboarding_1_primary">Let\'s Go</string>

    <!-- Onboarding - Page 2 (Permissions) -->
    <string name="onboarding_2_title">Allow Notifications &amp; Alarms</string>
    <string name="onboarding_2_body">LemurLoop needs permission to send notifications and schedule exact alarms. Without these, your alarms cannot fire.\n\nThis is required for the app to work.</string>
    <string name="onboarding_2_primary">Grant Permissions</string>
    <string name="onboarding_2_continue">Continue</string>
    <string name="onboarding_2_secondary">Skip (Not Recommended)</string>
    <string name="onboarding_2_permission_notifications">Notifications</string>
    <string name="onboarding_2_desc_notifications">Required to alert you when your alarm goes off.</string>
    <string name="onboarding_2_permission_alarms">Exact Alarms</string>
    <string name="onboarding_2_desc_alarms">Allows the app to wake you up at the precise minute you set.</string>
    <string name="onboarding_2_permission_overlay">Screen Overlay</string>
    <string name="onboarding_2_desc_overlay">Lets the alarm appear over other apps or on your lock screen.</string>

    <!-- Onboarding - Page 3 (Briefing) -->
    <string name="onboarding_3_title">Personas &amp; Personalization</string>
    <string name="onboarding_3_body">Choose your wake-up style! Our AI personas deliver your briefing with a unique twist:</string>
    <string name="onboarding_3_personas">\n• 🎖️ The Drill Sergeant: Tough love only.\n• 🎭 The Sarcastic Friend: Witty and dry.\n• 🧘 The Zen Master: Calm and mindful.\n• ⚡ The Hype-Man: High energy flow.</string>
    <string name="onboarding_3_label_name">I\'d like to be called… (Optional)</string>
    <string name="onboarding_3_hint_name">Enter your name to make it personal</string>
    <string name="onboarding_3_primary">Enable Briefing Features</string>
    <string name="onboarding_3_continue">Continue</string>
    <string name="onboarding_3_setup_progress">Briefing Setup: %1$d / %2$d</string>
    <string name="onboarding_3_setup_instructions">Grant permissions for your morning briefing</string>
    <string name="onboarding_3_permission_calendar">Calendar Events</string>
    <string name="onboarding_3_desc_calendar">Briefs you on today\'s schedule so you know what\'s ahead.</string>
    <string name="onboarding_3_permission_weather">Weather Report</string>
    <string name="onboarding_3_desc_weather">Tells you if you need an umbrella or sunglasses (requires location).</string>
    <string name="onboarding_3_setup_complete">Personalization ready! Click below to continue.</string>
    <string name="onboarding_3_secondary">Skip for Now</string>

    <!-- Onboarding - Page 4 (AI Features) -->
    <string name="onboarding_ai_title">Powered by Lemur AI</string>
    <string name="onboarding_ai_body">LemurLoop intelligently crafts your morning briefings. It defaults to our highly capable Cloud AI for the smartest wake-up possible, while offering a secure on-device Local AI fallback or classic text generation to suit your privacy and performance needs.</string>
    <string name="onboarding_ai_primary">Got It</string>

    <!-- Onboarding - Page 5 (Buddy) -->
    <string name="onboarding_4_title">Backup for Your Wake-Up</string>
    <string name="onboarding_4_body">Add an accountability buddy who will get a text if you snooze too many times or miss your alarm entirely. \n\nYou can set this up whenever you create or edit an alarm. **Pro tip: Try adding yourself first to see it in action!**</string>
    <string name="onboarding_4_primary">Sounds Great</string>
    <string name="onboarding_4_enable">Enable Buddy Backup</string>
    <string name="onboarding_4_permission_sms">SMS Access</string>
    <string name="onboarding_4_desc_sms">Needed to alert your buddy when you snooze</string>
    <string name="onboarding_4_secondary">Skip for Now</string>
    <string name="onboarding_4_secondary_next">Next</string>
    <string name="onboarding_buddy_assigned_prefix">Buddy assigned: </string>

    <!-- Onboarding - Page 5 (Finished) -->
    <string name="onboarding_5_title">You\'re All Set!</string>
    <string name="onboarding_5_body">Create your first alarm with the + button.\n\nChoose a wake-up persona in Settings to personalise your morning briefing.</string>
    <string name="onboarding_5_primary">Create My First Alarm</string>
    <string name="onboarding_5_secondary">Maybe Later</string>
