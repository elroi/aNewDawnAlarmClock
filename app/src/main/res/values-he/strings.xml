    <!-- Help screen -->
    <string name="help_screen_title">עזרה ותכונות</string>
    <string name="help_section_briefing_title">יצירת בריפינג השכמה</string>
    <string name="help_section_briefing_content">אינטליגנציית LemurLoop מתחילה ליצור את הבריפינג האישי שלך ברגע שהאזעקה מצלצלת. היא אוספת נתוני מזג אוויר, אירועי היומן ועובדה מהנה, ואז משתמשת ב-AI מתקדם לכתוב מחדש בקול הפרסונה שבחרת. עד שתבטל את האזעקה, הבריפינג מוכן! הערה: Cloud AI דורש חיבור אינטרנט יציב.</string>
    <string name="help_section_evasive_title">שינה מתחמקת</string>
    <string name="help_section_evasive_content">למי שנרדם תוך כדי נודניק! הפעל כדי שכפתור הנודניק יקפוץ למיקום אקראי אחר במסך בכל לחיצה. זה מאלץ אותך למקד את העיניים ולעקוב אחר הכפתור, ומקשה להמשיך לישון בטעות.</string>
    <string name="help_section_gentle_title">השכמה עדינה (קרשנדו)</string>
    <string name="help_section_gentle_content">דרך שלווה להתחיל את היום. במקום צליל חזק פתאומי, השכמה עדינה מתחילה את צליל האזעקה שבחרת ב-0% עוצמה ומגבירה בהדרגה למקסימום במשך כמה דקות. אפשר להתאים את משך העלייה בהגדרות מתקדמות.</string>
    <string name="help_section_fade_title">דעיכה חלקה</string>
    <string name="help_section_fade_content">כשתבטל או תנודנק את האזעקה, הצליל לא ייכבה בפתאומיות. LemurLoop מוריד את העוצמה בעדינות במשך שנייה אחת, למעבר חלק מהאזעקה לבריפינג או לשינה נוספת.</string>
    <string name="help_section_challenges_title">אתגרי מתמטיקה ופנים</string>
    <string name="help_section_challenges_content">הוכח שאתה ער! אתגרי מתמטיקה דורשים פתרון בעיות ברמת הקושי שבחרת. אתגרי פנים משתמשים במצלמה הקדמית כדי לוודא שאתה עושה הבעות מסוימות. תנועת שרירי הפנים וחישוב מנטלי עוזרים להעיר את המוח.</string>
    <string name="help_section_smart_title">בדיקת השכמה חכמה (אחריות)</string>
    <string name="help_section_smart_content">רשת הביטחון האולטימטיבית. כמה דקות אחרי ביטול האזעקה, LemurLoop שולח \'בדיקת דופק\'. אם לא תגיב תוך 60 שניות, המערכת תניח שנרדמת שוב ותפעיל אזעקה משנית חזקה או תשלח הודעה לחבר האחריות שבחרת.</string>
    <string name="help_section_buddy_title">חבר אחריות</string>
    <string name="help_section_buddy_content">הוסף חבר מהימן כחבר אחריות. אם לא תגיב לבדיקת השכמה חכמה, החבר יקבל הודעת SMS (בתעריף סטנדרטי) שיידע אותו שאתה תקוע במיטה וצריך השכמה אמיתית!</string>

