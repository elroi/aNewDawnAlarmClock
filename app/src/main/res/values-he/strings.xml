    <!-- Onboarding - Page 1 -->
    <string name="onboarding_back">חזרה</string>
    <string name="onboarding_1_title">פגוש את בן לווית ההשכמה החדש שלך</string>
    <string name="onboarding_1_body">LemurLoop הוא השעון המעורר שלא רק מעיר אותך — הוא הופך את זה לכיף!\nהוא מסכם לך את מזג האוויר, היומן והמשימה היומית, בהתאמה אישית ובקול הדמות שבחרת.</string>
    <string name="onboarding_1_primary">בוא נתחיל</string>

    <!-- Onboarding - Page 2 -->
    <string name="onboarding_2_title">אפשר התראות והתראות שעון</string>
    <string name="onboarding_2_body">LemurLoop צריך הרשאה לשלוח התראות ולתזמן שעונים מדויקים. בלי זה השעונים לא יופעלו.\n\nזה נדרש כדי שהאפליקציה תעבוד.</string>
    <string name="onboarding_2_primary">אפשר הרשאות</string>
    <string name="onboarding_2_continue">המשך</string>
